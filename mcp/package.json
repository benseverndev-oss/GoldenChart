{
  "name": "goldenchart-mcp",
  "version": "0.1.0",
  "description": "MCP server that renders GoldenChart sketchy charts and flowcharts as SVG.",
  "author": "Ben Severn",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/benseverndev-oss/GoldenChart.git",
    "directory": "mcp"
  },
  "homepage": "https://github.com/benseverndev-oss/GoldenChart/tree/main/mcp#readme",
  "bugs": {
    "url": "https://github.com/benseverndev-oss/GoldenChart/issues"
  },
  "keywords": ["mcp", "model-context-protocol", "goldenchart", "charts", "svg", "ai", "llm"],
  "license": "MIT",
  "type": "module",
  "bin": {
    "goldenchart-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsup",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "assets": "node scripts/generate-assets.mjs",
    "compare": "node scripts/compare-agent-surface.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.18.0",
    "@resvg/resvg-js": "^2.6.2",
    "goldenchart": "file:..",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "tsup": "^8.0.0",
    "tsx": "^4.16.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.7"
  }
}
