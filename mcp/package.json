{
  "name": "goldenchart-mcp",
  "version": "0.2.0",
  "description": "MCP server that renders GoldenChart sketchy charts and flowcharts as SVG.",
  "author": "Ben Severn",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/benseverndev-oss/GoldenChart.git",
    "directory": "mcp"
  },
  "homepage": "https://benseverndev-oss.github.io/GoldenChart/",
  "bugs": {
    "url": "https://github.com/benseverndev-oss/GoldenChart/issues"
  },
  "keywords": ["mcp", "model-context-protocol", "goldenchart", "charts", "svg", "ai", "llm"],
  "license": "MIT",
  "type": "module",
  "bin": {
    "goldenchart-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsup",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "assets": "node scripts/generate-assets.mjs",
    "compare": "node scripts/compare-agent-surface.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.18.0",
    "@resvg/resvg-js": "^2.6.2",
    "goldenchart": "file:..",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.16.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.7"
  }
}
